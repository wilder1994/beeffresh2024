APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Acceso panel (Database\Seeders\AdminUserSeeder). Cambiar en producción.
ADMIN_NAME="Administrador Beeffresh"
ADMIN_EMAIL=admin@beeffresh.local
ADMIN_PASSWORD=password

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
# Desarrollo: una sola BD. Las pruebas (phpunit.xml) fuerzan otra (…_test) para no vaciar esta con RefreshDatabase.
DB_DATABASE=beeffresh2024
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_CONNECTION=log
# Activar websockets: BROADCAST_CONNECTION=reverb (+ php artisan reverb:start)
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# Colas de notificaciones (requiere tabla jobs + php artisan queue:work)
NOTIFICATION_QUEUE=notifications
NOTIFICATION_EMAIL_QUEUE=notifications-email
NOTIFICATION_JOB_TRIES=3
NOTIFICATION_DELAYED_ORDER_MINUTES=45
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# Laravel Reverb (Fase 0 realtime)
REVERB_APP_ID=beeffresh-local
REVERB_APP_KEY=local-reverb-key
REVERB_APP_SECRET=local-reverb-secret
REVERB_HOST=localhost
REVERB_PORT=8081
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8081

# Google Maps (modal de dirección, Places, Geocoding). Restringir por sitio web en Google Cloud.
GOOGLE_MAPS_API_KEY=

# Pasarelas de pago (Wompi sandbox por defecto)
PAYMENT_DEFAULT_GATEWAY=wompi
PAYMENT_CURRENCY=COP
PAYMENT_TTL_MINUTES=60
PAYMENT_SHIPPING_FEE=0
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=
WOMPI_INTEGRITY_SECRET=
WOMPI_SANDBOX=true
WOMPI_API_BASE=https://sandbox.wompi.co/v1
WOMPI_WIDGET_URL=https://checkout.wompi.co/widget.js

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
